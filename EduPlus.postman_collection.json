{
  "info": {
    "name": "EduPlus API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"jdoe\",\n  \"email\": \"jdoe@eduplus.sn\",\n  \"password\": \"Passer123\",\n  \"role\": \"ETUDIANT\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Etudiants",
      "item": [
        {
          "name": "Lister (paginé)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/etudiants?page=0&size=10"
          }
        },
        {
          "name": "Créer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/etudiants",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"matricule\": \"ETU2026099\",\n  \"nom\": \"Kane\",\n  \"prenom\": \"Sokhna\",\n  \"email\": \"sokhna.kane@eduplus.sn\",\n  \"dateNaissance\": \"2003-05-10\"\n}"
            }
          }
        },
        {
          "name": "Modifier",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/etudiants/1"
          }
        },
        {
          "name": "Supprimer",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/etudiants/1"
          }
        },
        {
          "name": "Upload Photo",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/etudiants/1/photo",
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "" }]
            }
          }
        },
        {
          "name": "Upload Document PDF",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/etudiants/1/docs",
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "" }]
            }
          }
        }
      ]
    },
    {
      "name": "Cours",
      "item": [
        {
          "name": "Lister",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/cours"
          }
        }
      ]
    },
    {
      "name": "Inscriptions",
      "item": [
        {
          "name": "Inscrire un étudiant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/inscriptions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"etudiantId\": 1,\n  \"coursId\": 1\n}"
            }
          }
        }
      ]
    }
  ]
}
